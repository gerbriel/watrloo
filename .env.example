# Copy to .env.local and fill in from your Supabase project settings.
# Both values are safe to expose in a browser bundle: the publishable key is
# constrained by row level security. Never put the service_role key here.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxx
