# ==============================================================================
#  Watrloo environment
#
#  Copy to .env.local (gitignored) and fill in.
#
#  Two different kinds of variable live here, and mixing them up is how secrets
#  get published:
#
#    VITE_*   Read by Vite and INLINED INTO THE BROWSER BUNDLE. Anything with
#             this prefix is public the moment you deploy. Never give a secret
#             a VITE_ prefix.
#
#    everything else
#             Read by the shell scripts in scripts/, never by the app. Vite
#             loads them but does not expose them to client code. These ARE
#             secrets. See "Tooling secrets" below for how to load them.
# ==============================================================================


# ------------------------------------------------------------------------------
#  App — required. Public by design.
# ------------------------------------------------------------------------------
# The publishable (anon) key is constrained by row level security; it is meant to
# ship in the bundle. Never put the service_role key in a VITE_ variable — it
# bypasses RLS and would be handed to every visitor.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxx


# ------------------------------------------------------------------------------
#  App — basemap. Optional. Public by design.
# ------------------------------------------------------------------------------
# Plain static files you host yourself. Leave both unset and the map degrades to
# pins on a flat background — the app still runs. See docs/BASEMAP.md.
#
# The host must support HTTP Range requests and must expose `content-range` and
# `etag` via CORS, or range reads fail even though the network request succeeds.
VITE_BASEMAP_URL=https://<your-r2-public-host>/us-z13.pmtiles
# Base URL for the fonts/ and sprites/ directories. Self-hosted, NOT
# protomaps.github.io — pointing at their host reintroduces the third-party
# dependency this whole setup exists to remove.
VITE_BASEMAP_ASSETS_URL=https://<your-r2-public-host>/assets


# ==============================================================================
#  Tooling secrets — NOT read by the app. NOT public. Never prefix with VITE_.
#
#  The scripts read the *shell* environment, not this file. To use them:
#
#      set -a && source .env.local && set +a
#      ./scripts/upload-basemap.sh
#
#  Prefer exporting these ad-hoc in a shell instead of writing them to disk.
#  If a value here ever leaks (pasted in a chat, a log, an issue), rotate it.
# ==============================================================================


# ------------------------------------------------------------------------------
#  Cloudflare R2 — used by scripts/upload-basemap.sh to publish the basemap.
# ------------------------------------------------------------------------------
# Dashboard → R2 → Overview. A 32-char hex string, also visible in the S3
# endpoint URL.
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The bucket you created for the basemap.
R2_BUCKET=watrloo-basemap

# Dashboard → R2 → Manage API tokens → Create token, "Object Read & Write",
# scoped to the bucket above. Creating it yields an S3-compatible key pair.
# The secret is shown exactly once.
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional. Defaults to https://$R2_ACCOUNT_ID.r2.cloudflarestorage.com — set
# this only if you use a jurisdiction-specific endpoint (e.g. .eu).
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# Note: R2_* are for *uploading*. The app never sees them. What the app reads is
# the bucket's PUBLIC url, which goes in VITE_BASEMAP_URL above — either the
# r2.dev subdomain or a custom domain.


# ------------------------------------------------------------------------------
#  Supabase Management API — used by scripts/configure-auth.sh.
# ------------------------------------------------------------------------------
# A personal access token, NOT a project anon/service key:
#   https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_PROJECT_REF=<project-ref>


# ------------------------------------------------------------------------------
#  Custom SMTP — used by `scripts/configure-auth.sh set-smtp`.
# ------------------------------------------------------------------------------
# Supabase's built-in sender is capped at ~2 emails/hour project-wide and is
# explicitly not for production, so signup confirmation silently fails without
# this. See docs/ops/EMAIL.md.
#
# For Resend: username is the literal string "resend"; the password is your API
# key. SMTP_SENDER_EMAIL must be on a domain you have verified at
# resend.com/domains — with no verified domain, Resend will only deliver to the
# account owner's own address and every other signup bounces.
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMTP_SENDER_EMAIL=no-reply@<your-verified-domain>
SMTP_SENDER_NAME=Watrloo
