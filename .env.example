# Copy to .env.local and fill in from your Supabase project settings.
# Both values are safe to expose in a browser bundle: the publishable key is
# constrained by row level security. Never put the service_role key here.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxx

# --- Basemap (optional) ------------------------------------------------------
# Both are plain static files you host yourself. Leave them unset and the map
# degrades to pins on a flat background — the app still runs. See docs/BASEMAP.md.
#
# The .pmtiles archive. MapLibre reads byte ranges out of it over HTTP, so the
# host must support HTTP Range requests and must send permissive CORS headers.
VITE_BASEMAP_URL=https://<your-r2-public-host>/us-z13.pmtiles
# Base URL for the fonts/ and sprites/ directories (self-hosted, not
# protomaps.github.io — pointing at their host reintroduces a third-party dep).
VITE_BASEMAP_ASSETS_URL=https://<your-r2-public-host>/assets
